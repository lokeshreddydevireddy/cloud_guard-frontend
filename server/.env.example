# Backend environment
PORT=4000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# Mongo
MONGODB_URI=mongodb://127.0.0.1:27017/cloudvision

# JWT (generate strong values — e.g. `openssl rand -hex 64`)
JWT_SECRET=change_me_in_production
JWT_REFRESH_SECRET=change_me_in_production_refresh
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# SMTP (leave blank to log emails to console in development)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="CloudVision <no-reply@cloudvision.ai>"
